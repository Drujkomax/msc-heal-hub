# ============================================
# IMPORTANT: This file is NOT used by Lovable
# ============================================
# 
# Lovable projects use Supabase Secrets for server-side configuration.
# This file exists only as documentation for local development outside Lovable.
#
# For Lovable deployment:
# - Client-side config: Edit src/shared/config/constants.ts
# - Server-side secrets: Add via Supabase Dashboard → Project Settings → Edge Functions → Secrets
#

# ============================================
# SUPABASE CONFIGURATION (Auto-managed by Lovable)
# ============================================
# These are automatically configured by Lovable and should not be changed manually
VITE_SUPABASE_URL=https://smvbhwaupvbxqxqxzzjx.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================
# EDGE FUNCTION SECRETS (Configure in Supabase Dashboard)
# ============================================
# Go to: Supabase Dashboard → Your Project → Settings → Edge Functions → Secrets

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# JWT token for bot backend authentication
BOT_BACKEND_JWT=

# Supabase Service Role Key (only if needed for admin operations in Edge Functions)
SUPABASE_SERVICE_ROLE_KEY=

# ============================================
# OPTIONAL INTEGRATIONS
# ============================================
# Add any additional API keys or secrets needed by Edge Functions

# Sentry DSN for error tracking
SENTRY_DSN=

# Email service API key (if using external email provider)
EMAIL_API_KEY=

# SMS service API key (if using external SMS provider)
SMS_API_KEY=
